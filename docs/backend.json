
{
  "entities": {
    "VolunteerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VolunteerProfile",
      "type": "object",
      "description": "Represents a volunteer's profile, including their workforce status and current assignments.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the volunteer."
        },
        "name": {
          "type": "string",
          "description": "Full name."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": {
          "type": "string"
        },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["available", "busy"],
          "description": "Current workforce availability status."
        },
        "currentAssignment": {
          "type": "object",
          "properties": {
            "ngoId": { "type": "string" },
            "ngoName": { "type": "string" },
            "role": { "type": "string" },
            "taskId": { "type": "string" },
            "isPaid": { "type": "boolean" },
            "startTime": { "type": "string", "format": "date-time" },
            "endTime": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "skills", "location", "latitude", "longitude", "status", "createdAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a mission with workforce details.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "urgency": { "type": "string" },
        "priority": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "assigned", "completed"] },
        "assignedTo": { "type": "string" },
        "assignedVolunteerId": { "type": "string" },
        "isPaid": { "type": "boolean" },
        "workDuration": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "submittedBy": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "category", "location", "latitude", "longitude", "urgency", "priority", "status", "submittedBy", "createdAt"]
    },
    "ActivityLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActivityLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message", "type", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/volunteerProfiles/{volunteerId}",
        "definition": {
          "entityName": "VolunteerProfile",
          "schema": { "$ref": "#/backend/entities/VolunteerProfile" },
          "description": "Volunteer status tracking."
        }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": { "$ref": "#/backend/entities/Task" },
          "description": "Mission tracking."
        }
      },
      {
        "path": "/activities/{activityId}",
        "definition": {
          "entityName": "ActivityLog",
          "schema": { "$ref": "#/backend/entities/ActivityLog" },
          "description": "Real-time audit log."
        }
      }
    ]
  }
}
